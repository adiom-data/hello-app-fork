FROM golang:1.25-alpine AS build

WORKDIR /src

COPY go.mod ./
COPY api ./api

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/hello-app-api ./api

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/hello-app-api /hello-app-api

EXPOSE 18081
ENTRYPOINT ["/hello-app-api"]
